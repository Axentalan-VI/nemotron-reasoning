# Copy this file to `.env` (gitignored) and fill in real values.
# DO NOT put real secrets in this file — it is committed to git.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Teacher LLM — any OpenAI-compatible provider.
# Default: OpenRouter. Other examples:
#   NVIDIA build.nvidia.com : TEACHER_BASE_URL=https://integrate.api.nvidia.com/v1  TEACHER_MODEL=nvidia/nemotron-3-super-120b-a12b
#   DeepSeek direct         : TEACHER_BASE_URL=https://api.deepseek.com/v1         TEACHER_MODEL=deepseek-chat
#   Self-hosted vLLM        : TEACHER_BASE_URL=http://localhost:8000/v1            TEACHER_MODEL=nvidia/nemotron-3-super-120b-a12b
TEACHER_PROVIDER=openrouter
TEACHER_BASE_URL=https://openrouter.ai/api/v1
TEACHER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TEACHER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_API_KEY=
